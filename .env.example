# Netlify build hook URL — triggers a new build/deploy when the admin hits "Sync Google Sheet".
# Set this in your Netlify site settings under Site configuration > Build hooks.
# Copy the generated URL and paste it here (and into Netlify's environment variables for production).
VITE_NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/YOUR_HOOK_ID_HERE
